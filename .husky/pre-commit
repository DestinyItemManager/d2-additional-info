files=$(git diff --cached --name-only --diff-filter=ACM -- '*.ts' '*.js' '*.json')
[ -z "$files" ] && exit 0
# --no-error-on-unmatched-pattern so staged files covered by ignore rules
# (e.g. generated output/*.json) don't fail the commit.
echo "$files" | xargs pnpm exec oxfmt --no-error-on-unmatched-pattern
echo "$files" | xargs git add
