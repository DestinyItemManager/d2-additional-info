{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "singleQuote": true,
  "arrowParens": "always",
  "sortPackageJson": false,
  "ignorePatterns": [
    "Destiny-2-Font-Symbols",
    "manifest_tables/*.json",
    "manifests/*",
    "data/**/*.json",
    "output/**/*.json",
    "built/*",
    ".vscode",
    "node_modules/",
    "pnpm-lock.yaml",
    "*.md",
    "*.yml",
    "*.yaml",
    "!output/seasonal-challenges.json",
    "!output/pursuits.json",
    "!output/crafting-mementos.json",
    "!output/season-to-source.json"
  ]
}
