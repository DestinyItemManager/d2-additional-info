{
  "compilerOptions": {
    "outDir": "./built",
    "rootDir": ".",
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "target": "ESnext",
    "module": "ESnext",
    "typeRoots": ["./src/@types", "./node_modules/@types"],
    "types": ["node"]
  },
  "include": ["./src/**/*"]
}
